{
  "name": "@vaed-ai/cyto",
  "version": "0.0.2",
  "description": "React components for Cytoscape.js — declarative nodes with React content inside",
  "homepage": "https://vaed-ai.github.io/cyto",
  "repository": {
    "type": "git",
    "url": "https://github.com/vaed-ai/cyto.git"
  },
  "main": "dist/index.js",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./*": {
      "types": "./dist/*.d.ts",
      "default": "./dist/*.js"
    }
  },
  "license": "UNLICENSED",
  "type": "module",
  "keywords": [
    "cytoscape",
    "react",
    "react-cytoscape",
    "graph",
    "network",
    "visualization",
    "declarative",
    "jsx",
    "react-content",
    "force-directed",
    "cola",
    "cytoscape-react"
  ],
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "build:pkg": "tsc --project tsconfig.pkg.json",
    "prepublishOnly": "npm run build:pkg",
    "start": "next start"
  },
  "dependencies": {
    "cytoscape": "^3.31.0",
    "cytoscape-cola": "^2.5.1",
    "react-cytoscapejs": "^2.0.0"
  },
  "peerDependencies": {
    "react": "^18.0.0",
    "react-dom": "^18.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/react": "^18.0.0",
    "@types/react-dom": "^18.0.0",
    "next": "^14.2.32",
    "prism-react-renderer": "^2.4.1",
    "react": "^18.0.0",
    "react-dom": "^18.0.0",
    "typescript": "^5.0.0"
  }
}
